# Binary mod files — treat as binary, no line-ending conversion, no diff
*.EXMODZ binary
*.pak binary
*.uasset binary
*.uexp binary
*.png binary

# Force LF line endings for text files
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.txt text eol=lf
*.xml text eol=lf

# EXMOD files are JSON text but can be large
*.EXMOD text eol=lf diff
