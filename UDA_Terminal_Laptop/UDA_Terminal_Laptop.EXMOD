          "FlavorText": "NSLOCTEXT(\"D_Itemable\", \"Item_UDA_Terminal_Laptop-FlavorText\", \"Group 15 Issue. Authorised connection to UDA orbital systems. Refurbished from a recovered ICA hab unit.\")",
